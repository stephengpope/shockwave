{
  "name": "shockwave",
  "version": "1.0.11",
  "description": "Shockwave — markdown-vault editor",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch --remoteDebuggingPort=9222",
    "cli-tools": "npm --prefix cli-tools install --no-audit --no-fund && node scripts/clean-cli-tools.mjs",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "test": "node --test \"tests/**/*.test.js\"",
    "lint": "eslint \"src/**/*.{js,jsx,cjs,ts,tsx}\" \"tests/**/*.js\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "ui:diff": "node scripts/ui-diff.mjs"
  },
  "keywords": [],
  "author": "Stephen G. Pope",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@earendil-works/pi-ai": "0.80.5",
    "@earendil-works/pi-coding-agent": "0.80.5",
    "@excalidraw/excalidraw": "^0.18.1",
    "@parcel/watcher": "^2.5.6",
    "arctic": "^3.7.0",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "cron-parser": "^5.6.2",
    "date-fns": "^4.4.0",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.9",
    "force-graph": "^1.51.4",
    "fuzzysort": "^3.1.0",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.6",
    "react-arborist": "^3.7.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "build": {
    "appId": "com.sgplabs.shockwave",
    "productName": "Shockwave",
    "publish": {
      "provider": "github",
      "owner": "stephengpope",
      "repo": "shockwave",
      "releaseType": "release"
    },
    "files": [
      "out/**",
      "build/icon.png",
      "cli-tools/**",
      "!cli-tools/node_modules/.bin",
      "!cli-tools/node_modules/.bin/**"
    ],
    "asarUnpack": [
      "cli-tools/**",
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "resources/built-in-skills",
        "to": "built-in-skills"
      },
      {
        "from": "drizzle",
        "to": "drizzle"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "artifactName": "Shockwave-mac.${ext}",
      "hardenedRuntime": true,
      "notarize": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Shockwave uses the microphone for voice transcription."
      }
    },
    "dmg": {
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Shockwave-windows.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon-linux.png",
      "category": "Office",
      "artifactName": "Shockwave-linux.${ext}"
    }
  }
}
