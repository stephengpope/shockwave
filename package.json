{
  "name": "shockwave",
  "version": "1.0.5",
  "description": "Shockwave — markdown-vault editor",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch --remoteDebuggingPort=9222",
    "cli-tools": "npm --prefix cli-tools install --no-audit --no-fund && node scripts/clean-cli-tools.mjs",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder",
    "test": "node --test \"tests/**/*.test.js\"",
    "lint": "eslint \"src/**/*.{js,jsx,cjs,ts,tsx}\" \"tests/**/*.js\"",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Stephen G. Pope",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@earendil-works/pi-ai": "0.75.4",
    "@earendil-works/pi-coding-agent": "0.75.4",
    "@excalidraw/excalidraw": "^0.18.1",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "dayjs": "^1.11.20",
    "diff": "^9.0.0",
    "force-graph": "^1.51.4",
    "fuzzysort": "^3.1.0",
    "react": "^19.2.6",
    "react-arborist": "^3.7.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "build": {
    "appId": "com.example.shockwave",
    "productName": "Shockwave",
    "publish": {
      "provider": "github",
      "owner": "stephengpope",
      "repo": "shockwave",
      "releaseType": "release"
    },
    "files": [
      "out/**",
      "build/icon.png",
      "cli-tools/**",
      "!cli-tools/node_modules/.bin",
      "!cli-tools/node_modules/.bin/**"
    ],
    "asarUnpack": [
      "cli-tools/**"
    ],
    "extraResources": [
      {
        "from": "resources/built-in-skills",
        "to": "built-in-skills"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "artifactName": "Shockwave-mac.${ext}"
    },
    "dmg": {
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "Shockwave-windows.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon-linux.png",
      "category": "Office",
      "artifactName": "Shockwave-linux.${ext}"
    }
  }
}
