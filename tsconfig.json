{
  // Incremental TypeScript: .ts/.tsx are type-checked, the existing .js/.jsx
  // majority is seen for module resolution only (allowJs + checkJs:false).
  // esbuild (via electron-vite) does the actual building and strips types
  // WITHOUT checking them — `npm run typecheck` (tsc --noEmit) is the real gate.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    // Migration posture: keep strict's real bug-catching (null-safety, type
    // mismatches) but don't force an annotation on every internal param while
    // landing the .js→.ts conversion. Exported/contract signatures are still
    // typed by hand. Ratchet this to true later for full coverage.
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false,
    // "@/..." resolves inside the renderer only — used by shadcn/ui components.
    "paths": { "@/*": ["./src/renderer/*"] }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.d.ts"],
  "exclude": ["node_modules", "out", "dist"]
}
