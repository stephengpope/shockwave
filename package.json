{
  "name": "shockwave",
  "version": "1.0.0",
  "description": "Shockwave — markdown-vault editor",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder",
    "test": "node --test \"tests/**/*.test.js\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.13",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.78",
    "@ai-sdk/openai": "^3.0.64",
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "ai": "^6.0.189",
    "chokidar": "^5.0.0",
    "codemirror": "^6.0.2",
    "force-graph": "^1.51.4",
    "react": "^19.2.6",
    "react-arborist": "^3.7.0",
    "react-dom": "^19.2.6"
  },
  "build": {
    "appId": "com.example.shockwave",
    "productName": "Shockwave",
    "files": [
      "electron/**",
      "dist/**"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon-linux.png",
      "category": "Office"
    }
  }
}
